# Supabase (public — safe for client bundle)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Public app URL for open-tracking pixel (use ngrok or production URL in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase service role — server only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google OAuth (Supabase Auth + Gmail API)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Gmail refresh token for the shared info@ mailbox (server / edge functions only)
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# OpenAI (edge functions + optional Next.js embeddings)
OPENAI_API_KEY=your_openai_api_key

# Optional overrides
# OPENAI_MODEL=gpt-4o-mini
